{
    "title": "Research MCP Server Results",
    "type": "object",
    "properties": {
        "tool": {
            "type": "string",
            "description": "Tool name that was called"
        },
        "query": {
            "type": "string",
            "description": "Query or URL passed to the tool"
        },
        "count": {
            "type": "integer",
            "description": "Number of results returned"
        },
        "results": {
            "type": "array",
            "description": "Tool results array"
        },
        "error": {
            "type": "string",
            "description": "Error message if tool failed"
        }
    },
    "required": ["tool", "query", "count"]
}
